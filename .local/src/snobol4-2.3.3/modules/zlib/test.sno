-include 'zlib.sno'

	SRC = "Mary had a little little little little lamb."
	OUTPUT = SIZE(SRC)

	COMPRESSED = ZLIB_COMPRESS(SRC)
	OUTPUT = SIZE(COMPRESSED)

	UNCOMPRESSED = ZLIB_UNCOMPRESS(COMPRESSED)
	OUTPUT = SIZE(UNCOMPRESSED)
	OUTPUT = UNCOMPRESSED

	OUTPUT = ZLIB_CRC32(SRC)
	OUTPUT = ZLIB_ADLER32(SRC)
END
