-INCLUDE 'logic.sno'

	DEFINE('TEST(EXPR,EXPECT)')			:(TEST.END)
TEST	VAL = 'FAILURE'
	VAL = EVAL(EXPR)				:F(TEST.FAIL)
	IDENT(VAL,EXPECT)				:S(RETURN)
TEST.FAIL
	OUTPUT = 'ERROR: ' EXPR ' GOT: ' VAL ' EXPECTED: ' EXPECT
	:(ERROR)
TEST.END

	TEST('NOT(0)', -1)
	TEST('NOT(CHAR(0))', CHAR(255))

	TEST('AND(1,3)', 1)
	TEST('AND(CHAR(1), CHAR(3))', CHAR(1))
	TEST('AND("a", 215)', 'A')
	TEST('AND("XYZ", 254)', 'XXZ')
	TEST('AND("XYZ", CHAR(254) CHAR(253) CHAR(252))', 'XYX')

	TEST('OR(1,2)', 3)
	TEST('OR(CHAR(1), CHAR(2))', CHAR(3))
	TEST('OR("UVW", 15)', '___')
	TEST('OR("UVW", CHAR(15) CHAR(15) CHAR(15))', '___')

	TEST('XOR(1,3)', 2)
	TEST('XOR(CHAR(1), CHAR(3))', CHAR(2))

	TEST('NAND(3,1)', -2)
	TEST('NAND(CHAR(3), CHAR(1))', CHAR(254))

	TEST('NOR(1,3)', -4)
	TEST('NOR(CHAR(1), CHAR(3))', CHAR(252))

*	UPLUS

	:(END)

ERROR	&CODE = 1
END
