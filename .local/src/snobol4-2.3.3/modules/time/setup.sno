-INCLUDE 'setuputil.sno'

	t = TABLE()
	t['module'] = 'time'
	t['sources'] = 'time.c,' SLEEP_C
	t['cflags'] = TIME_CFLAGS
	t['ldflags'] = TIME_LDFLAGS

	t['author'] = t['maintainer'] = 'Phil Budne'
	t['author_email'] = t['maintainer_email'] = 'phil@regressive.org'
	t['license'] = 'BSD'
	t['tests'] = 'test.sno,test2.sno'

* description
* long_description
* version (get from RCS ID?)

	setup(t)
end
