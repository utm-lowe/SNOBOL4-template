-include 'digest.sno'
	&CODE = 1
	TEST = "This is a test string" CHAR(10)

* fails if algorithm unknown
* exits (w/ exit status 1) on any other error
	DEFINE("T(ALG,REF)CTX,TMP")		:(ET)
T	CTX = DIGEST_INIT(ALG)			:F(FRETURN)
	DIGEST_UPDATE(CTX,TEST)			:F(T.ERR)
	TMP = DIGEST_HEX(DIGEST_FINAL(CTX))	:F(T.ERR)
	TERMINAL = IDENT(TMP,REF) ALG " OK"	:S(RETURN)
	OUTPUT = ALG " failed"
	OUTPUT = "GOT: " TMP
	OUTPUT = "EXP: " REF			:(END)
T.ERR	OUTPUT = ALG " error"			:(END)
ET

****************
* MD5 and SHA-1: MUST PASS
	T("md5","b584c39f97dfe71ebceea3fdb860ed6c")	:F(END)
	T("sha1","c4af1fb1a2c5a9b67305424eda71bcd91e183f2c") :F(END)

****************
* SHA-2 family: all or none.
	T("sha224","58a912ba31da65dc2fef416a6f4b5d80f410346084f5bb252ae2db6b")
+							:F(DONE)
	T("sha256","85b783158409d3cde4d6b3e8ae5dc75f2470642e13a0a78853b91a18621b1346")
+							:F(END)
	T("sha384","080be3d7f1aa6b6babb85483f5c80e0cd57c014ed8037b679444751a2ee2be46c07f0edb85e05e6de98173658e4de1b5")
+							:F(END)
	T("sha512","ab6ddc5c40d0ed2fcdbf00c71ff80811c2b6eb274dccce690a50a6f7595fca2a8d3ceea1df07c89528b47ad6f7aa6980f800a5111bdf1374df3b52fe929ef4b2")
+							:F(END)

****************
* SHA-3 family: all or none
	T("sha3-224","ce7a0fbe5a3df4990ca5a458baf72043c1b24b57d7a60706e7614b82")
+							:F(DONE)
	T("sha3-256","faf3ff6d06f9de809e6765998dfbe5cd7ba0d08df58fcdbd20f18329851490ef")
	T("sha3-384","8dc1c0260546847a0e3326aa6f0aade73f7631263e7694735ba95e603c910fca1bc07ab3e71e8cfb5dbb3e60b5581a0f")
+							:F(END)
	T("sha3-512","3141c7d076b499713799556cacc7fc78e793361c8a5ac4d9b4972da977ba3f107b672da6c9798a479247003e652e55e4c81f96909d1469e5dbe0d17bb4a57898")
+							:F(END)

DONE	OUTPUT = "OK"
	&CODE = 0

END
