-include 'base64.sno'

* uncomment for trace:
	define('t(x)d,e')				:(et)
t	total = total + 1
	debug = x
	debug = e = base64_encode(x)			:f(ef)
	debug = d = base64_decode(e)			:f(df)
	ident(x,d)					:(return)
	errors = errors + 1
	terminal = 'in:  ' x
	terminal = 'enc: ' e
	terminal = 'dec: ' d				:(freturn)

ef	output = 'encode failed: ' x			:(freturn)
df	output = 'decode failed: ' e			:(freturn)
et

	errors = total = 0
	t('hello world.')
	t('hello world..')
	t('hello world...')
	t('hello world....')
* http://doc.cat-v.org/plan_9/4th_edition/papers/utf (1993)
	t('Καλημέρα κόσμε')
	t('こんにちは 世界')
	t(&ALPHABET)
	t('👍😊🥺😉😍😘😚😜😂😝😳😁😣😢😭😰🥰🥴😏🍆🍑')

	output = ''
	output = total ' tests ' errors ' errors'
	&CODE = errors
end
